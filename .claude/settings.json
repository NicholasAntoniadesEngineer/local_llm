{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "defaultMode": "acceptEdits",
  "permissions": {
    "ask": [
      "WebFetch",
      "WebSearch",
      "mcp__cursor-ide-browser__*",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(git clone *)",
      "Bash(npm install *)",
      "Bash(npm ci *)",
      "Bash(npm add *)",
      "Bash(npm i *)",
      "Bash(npm uninstall *)",
      "Bash(npm update *)",
      "Bash(npx *)",
      "Bash(yarn add *)",
      "Bash(yarn install *)",
      "Bash(yarn global *)",
      "Bash(pnpm add *)",
      "Bash(pnpm install *)",
      "Bash(pnpm i *)",
      "Bash(pnpm update *)",
      "Bash(bun install *)",
      "Bash(bun add *)",
      "Bash(pip install *)",
      "Bash(pip3 install *)",
      "Bash(python -m pip install *)",
      "Bash(python3 -m pip install *)",
      "Bash(pip uninstall *)",
      "Bash(pip3 uninstall *)",
      "Bash(uv pip *)",
      "Bash(uv add *)",
      "Bash(uv sync *)",
      "Bash(uv tool install *)",
      "Bash(poetry add *)",
      "Bash(poetry install *)",
      "Bash(poetry update *)",
      "Bash(conda install *)",
      "Bash(conda update *)",
      "Bash(mamba install *)",
      "Bash(gem install *)",
      "Bash(cargo install *)",
      "Bash(cargo add *)",
      "Bash(go install *)",
      "Bash(go get *)",
      "Bash(apt install *)",
      "Bash(apt-get install *)",
      "Bash(sudo apt install *)",
      "Bash(sudo apt-get install *)",
      "Bash(brew install *)",
      "Bash(brew upgrade *)",
      "Bash(brew tap *)",
      "Bash(dnf install *)",
      "Bash(yum install *)",
      "Bash(snap install *)",
      "Bash(flatpak install *)"
    ],
    "allow": [
      "Bash",
      "Read",
      "Edit",
      "Write",
      "Grep",
      "Glob",
      "NotebookEdit",
      "Agent",
      "TaskCreate",
      "TaskGet",
      "TaskList",
      "TaskOutput",
      "TaskStop",
      "TaskUpdate",
      "KillShell",
      "LSP",
      "TodoWrite",
      "ToolSearch",
      "Skill",
      "ExitPlanMode",
      "mcp__*"
    ]
  }
}
