# LLM Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL_REASONING=qwen3:32b
OLLAMA_MODEL_FAST=qwen3:8b
OLLAMA_MODEL_MOE=qwen3:30b-a3b
OLLAMA_MODEL_CODE=qwen2.5-coder:32b

# MLX Configuration (2x faster inference on Apple Silicon)
USE_MLX=true
MLX_MODEL_REASONING=mlx-community/Qwen3-32B-4bit
MLX_CACHE_DIR=~/.cache/mlx

# Web Search
TAVILY_API_KEY=tvly-xxx_your_api_key_here
TAVILY_INCLUDE_ANSWER=true

# Memory Configuration
LANCEDB_PATH=./data/research_memory.lancedb
SQLITE_DB_PATH=./data/agent_state.db

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/agent.log

# Agent Configuration
MAX_CONTEXT_TOKENS=16384
MAX_STEPS=30
REFLECTION_THRESHOLD=0.8
RULE_IMPROVEMENT_THRESHOLD=0.05

# Optional: Advanced
ENABLE_SPECULATIVE_DECODING=false
DEBUG_MODE=false
